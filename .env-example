  # GLOBAL VARIABLES

  NG_APP_OPENCAGEAPIKEY=your-opencage-api-key # GeoCoding API Key https://opencagedata.com/
  NG_APP_GIPHYAPIKEY=your-giphy-api-key # Giphy API Key
  NG_APP_APIWEATHERURL=https://api.weatherapi.com/v1/forecast.json # Weather API Service URL
  NG_APP_APIWEATHERTOKEN=your-weather-api-token # Weather API Service TOKEN

  # LOCAL ENVIRONMENT

  NG_APP_BASE_URL=http://localhost:4200
  NG_APP_API_URL=http://localhost:3000/api/v1 # Worky API Service Core
  NG_APP_WSURL=http://localhost:3011 # Worky WebSocket service
  NG_APP_APINOTIFICATIONCENTER=http://localhost:3010/api/v1 # Notification Center API Service URL
  NG_APP_APIFILESERVICE=http://localhost:3005/ # File Service URL
  NG_APP_MINIO_BUCKET_URL=https://your-minio-host/your-bucket-name # MinIO Bucket URL for files
  NG_APP_APIMESSAGESERVICE=http://localhost:3003/api/v1 # Message Service URL
  NG_APP_APIGEOLOCATIONS=http://localhost:3013/api/v1 # GeoLocations API Service URL
  NG_APP_TEMPLATE_EMAIL_LOGO=assets/img/widget/logo-worky-100.png

  NG_APP_CACHE_DEBUG=true # Enable cache debug mode
  NG_APP_CACHE_ENABLED=true # Enable application cache
  NG_APP_VERSION_LOGS_ENABLED=true # Enable version logs

  NG_APP_CLIEN_ID_GOOGLE=your-google-client-id.apps.googleusercontent.com # Google OAuth Client ID

  # META TAGS

  NG_APP_META_TITLE="Page title"
  NG_APP_META_DESCRIPTION="Page description"
  NG_APP_META_KEYWORDS="keyword1, keyword2, keyword3"
  NG_APP_META_IMAGE="https://your-domain.com/og-image.png"
  NG_APP_META_URL="https://your-domain.com"
  NG_APP_META_OG_TYPE="website"
  NG_APP_META_OG_SITE_NAME="Site name"
  NG_APP_META_OG_URL="https://your-domain.com"
  NG_APP_META_OG_TITLE="Open Graph title"
  NG_APP_META_OG_DESCRIPTION="Open Graph description"
  NG_APP_META_OG_IMAGE="https://your-domain.com/og-image.png"
  NG_APP_META_TWITTER_CARD="summary_large_image"
  NG_APP_META_TWITTER_URL="https://your-domain.com"
  NG_APP_META_TWITTER_TITLE="Twitter title"
  NG_APP_META_TWITTER_DESCRIPTION="Twitter description"
  NG_APP_META_TWITTER_IMAGE="https://your-domain.com/og-image.png"

  # PWA

  NG_APP_PWA_NAME="Worky"
  NG_APP_PWA_SHORT_NAME="Worky"
  NG_APP_PWA_BACKGROUND_COLOR="ffffff"
  NG_APP_PWA_THEME_COLOR="000000"

  # FIREBASE

  NG_APP_FIREBASE_API_KEY=your-firebase-api-key
  NG_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
  NG_APP_FIREBASE_PROJECT_ID=your-project-id
  NG_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
  NG_APP_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
  NG_APP_FIREBASE_APP_ID=your-firebase-app-id
  NG_APP_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX
  NG_APP_FIREBASE_VAPID_KEY=your-vapid-key

  # MOBILE CACHE

  NG_APP_MOBILE_CACHE_ENABLED=true
  NG_APP_MOBILE_CACHE_SIZE=50
  NG_APP_MOBILE_PRELOAD_THRESHOLD=3
  NG_APP_MOBILE_COMPRESSION_ENABLED=true
