# Angular frontend environment (build-time, injected via @ngx-env — must be prefixed NG_APP_)
# Copy to .env and fill in. Do NOT commit the real .env.

# --- Core origins ---
# Site origin (where the SPA is served).
NG_APP_BASE_URL="http://localhost:4200"
# Main API base (usually includes the /api/v1 prefix).
NG_APP_API_URL="http://localhost:3000/api/v1"
# WebSocket (connect-service) URL.
NG_APP_WSURL="ws://localhost:3011"
# Note: the public share page (/p/:id) is served by the backend; its link is derived from
# NG_APP_API_URL (stripping a trailing /api or /api/v1). No dedicated variable needed.

# --- Microservice endpoints ---
NG_APP_APIFILESERVICE="http://localhost:3005"
NG_APP_MINIO_BUCKET_URL=""
NG_APP_APIMESSAGESERVICE="http://localhost:3003/api/v1"
NG_APP_APINOTIFICATIONCENTER="http://localhost:3010/api/v1"
NG_APP_APIGEOLOCATIONS="http://localhost:3013/api/v1"

# --- Auth / third-party ---
NG_APP_CLIEN_ID_GOOGLE="your-google-client-id.apps.googleusercontent.com"
NG_APP_GIPHYAPIKEY="your-giphy-api-key"
NG_APP_OPENCAGEAPIKEY="your-opencage-api-key"
NG_APP_APIWEATHERURL="https://api.openweathermap.org/data/2.5"
NG_APP_APIWEATHERTOKEN="your-openweather-token"

# --- Caching ---
NG_APP_CACHE_DEBUG="false"
NG_APP_CACHE_ENABLED="false"
NG_APP_VERSION_LOGS_ENABLED="false"

# --- Static meta tags (site-level, set at app boot) ---
NG_APP_META_TITLE="Worky"
NG_APP_META_DESCRIPTION="Worky social network"
NG_APP_META_KEYWORDS="social, network"
NG_APP_META_IMAGE=""
NG_APP_META_URL="http://localhost:4200"
NG_APP_META_OG_SITE_NAME="Worky"
NG_APP_META_OG_URL="http://localhost:4200"
NG_APP_META_OG_TITLE="Worky"
NG_APP_META_OG_DESCRIPTION="Worky social network"
NG_APP_META_OG_IMAGE=""
NG_APP_META_TWITTER_CARD="summary_large_image"
NG_APP_META_TWITTER_URL="http://localhost:4200"
NG_APP_META_TWITTER_TITLE="Worky"
NG_APP_META_TWITTER_DESCRIPTION="Worky social network"
NG_APP_META_TWITTER_IMAGE=""
NG_APP_TEMPLATE_EMAIL_LOGO=""

# --- PWA ---
NG_APP_PWA_NAME="Worky"
NG_APP_PWA_SHORT_NAME="Worky"
NG_APP_PWA_BACKGROUND_COLOR="#ffffff"
NG_APP_PWA_THEME_COLOR="#6366f1"

# --- Firebase (push) ---
NG_APP_FIREBASE_API_KEY=""
NG_APP_FIREBASE_APP_ID=""
NG_APP_FIREBASE_AUTH_DOMAIN=""
NG_APP_FIREBASE_MEASUREMENT_ID=""
NG_APP_FIREBASE_MESSAGING_SENDER_ID=""
NG_APP_FIREBASE_PROJECT_ID=""
NG_APP_FIREBASE_STORAGE_BUCKET=""
NG_APP_FIREBASE_VAPID_KEY=""
